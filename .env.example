# Copy to `.env` and fill in. Any key left blank makes Mark use the offline/mock
# path for that provider (the pipeline still runs end-to-end, producing real
# local media files — it just won't call the real API or post anything live).

OPENAI_API_KEY=          # Text generation, image generation, TTS, embeddings
FAL_KEY=                 # Video generation via fal.ai
UPLOAD_POST_API_KEY=     # Social media posting via upload-post.com
ELEVENLABS_API_KEY=      # (optional) Higher-quality TTS voices

# Optional global override: set to 1 to force offline/mock mode even when keys
# are present (useful for dry runs and development).
MARK_MOCK=

# Optional — humor radar / trend radar source upgrades:
TENOR_API_KEY=            # Google Cloud key for Tenor v2 (trending GIFs; the "GIF Keyboard" data)
REDDIT_CLIENT_ID=         # free Reddit "script" app → real upvote velocity + higher rate limits
REDDIT_CLIENT_SECRET=     # (without these, Mark falls back to politely-paced public RSS feeds)

# Optional — clip-economy templates (all have offline/mock fallbacks):
PEXELS_API_KEY=           # motivational b-roll (free, commercial, no attribution)
PIXABAY_API_KEY=          # motivational b-roll fallback
FREESOUND_API_KEY=        # SFX engine — CC0 sound effects (freesound.org/apiv2/apply); synthesizes offline without it
TWITCH_CLIENT_ID=         # livestream clipping — Twitch Helix (get_streams/get_clips)
TWITCH_CLIENT_SECRET=     # (app access token via client-credentials)
